generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // The 'url' line is removed from here!
}

model Video {
  id          String    @id @default(uuid())
  title       String
  description String?
  videoUrl    String
  userId      String
  createdAt   DateTime  @default(now())
  thumbnailUrl String?
  comments    Comment[]
}

model Comment {
  id        String   @id @default(uuid())
  videoId   String
  userId    String
  text      String
  createdAt DateTime @default(now())
  Video     Video    @relation(fields: [videoId], references: [id])
}
